{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "dist/typedoc",
  "name": "WebGPU FFT Library",
  "readme": "README.md",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "navigationLinks": {
    "GitHub": "https://github.com/LessUp/gpu-fft",
    "npm": "https://www.npmjs.com/package/webgpu-fft"
  },
  "plugin": [],
  "theme": "default",
  "hideGenerator": true,
  "searchInComments": true,
  "categorizeByGroup": true,
  "sort": ["source-order"],
  "visibilityFilters": {
    "protected": false,
    "private": false,
    "inherited": true,
    "external": false
  }
}
